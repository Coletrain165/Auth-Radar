# Auth Radar - Environment Configuration
# Copy this file to .env and fill in your values.

# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1

# --- PDF ---
PDF_PASSWORD=your_pdf_password_here

# --- Dropbox ---
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REFRESH_TOKEN=
DROPBOX_ROOT_FOLDER=

# --- Caspio (optional, for patient name matching) ---
CASPIO_ACCOUNT_ID=
CASPIO_CLIENT_ID=
CASPIO_CLIENT_SECRET=
CASPIO_TABLE_NAME=a_Authorizations

# --- Azure Document Intelligence (optional, legacy) ---
AZURE_DOCUMENTINTELLIGENCE_ENDPOINT=
AZURE_DOCUMENTINTELLIGENCE_KEY=
AZURE_DOCUMENTINTELLIGENCE_MODEL_ID=Pace_Auth_Model_V2
